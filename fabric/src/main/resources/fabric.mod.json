{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "PrismProtect — server-side block, entity and container logging with rollback support.",
  "authors": [
    "${mod_authors}"
  ],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.lanis.prismprotect.fabric.PrismProtectFabric"
    ],
    "client": [
      "dev.lanis.prismprotect.fabric.PrismProtectFabricClient"
    ],
    "modmenu": [
      "dev.lanis.prismprotect.fabric.client.PrismProtectModMenuIntegration"
    ]
  },
  "mixins": [
    "mixins.prismprotect.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": ">=${minecraft_ver} <=1.20.4",
    "architectury": ">=9.0.0",
    "fabric-api": "*"
  }
}
